tmp/
.agents/
.codex/
__pycache__/
*.py[cod]

# Local Python virtualenvs (see CLAUDE.md dev setup)
.venv/
venv/
.pytest_cache/


# Mutable protected local governance state; never commit or include in Release source fingerprints.
.runtime_governance_state/

# Local (per-environment) Core activation state. The approved Core Release under
# THOMAS_CORE/releases/ is shared; activation is a local runtime step (see CLAUDE.md),
# so the current pointer lives in .runtime_governance_state/ and these stay local.
THOMAS_CORE/activations/
THOMAS_CORE/approvals/
THOMAS_CORE/CURRENT_CORE_RELEASE.yaml

# R8 approved internal workspace — the only tree the agent may write into. Its contents
# are per-machine runtime output, never shared source, so a controlled write can never
# reach a commit.
workspace/

# pytest --basetemp target (CLAUDE.md workaround for the pytest-of-thomas PermissionError)
.pytest_tmp/
