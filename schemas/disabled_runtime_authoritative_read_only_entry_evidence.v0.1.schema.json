{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "disabled_runtime_authoritative_read_only_entry_evidence.v0.1.schema.json",
  "title": "Disabled Runtime-Authoritative Read-only Entry Evidence v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "evidence_id",
    "phase",
    "status",
    "entry_plan",
    "adapter",
    "checks",
    "decision",
    "runtime_effect",
    "integrity",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "disabled_runtime_authoritative_read_only_entry_evidence.v0.1"
    },
    "evidence_id": {
      "type": "string",
      "pattern": "^entryev_[A-Za-z0-9._:-]+$"
    },
    "phase": {
      "const": "I0.5.2"
    },
    "status": {
      "const": "BLOCKED_DISABLED_ENTRY_ADAPTER"
    },
    "entry_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_plan_id",
        "entry_plan_ref",
        "entry_plan_sha256",
        "entry_plan_decision"
      ],
      "properties": {
        "entry_plan_id": {
          "type": "string",
          "pattern": "^entryplan_[A-Za-z0-9._:-]+$"
        },
        "entry_plan_ref": {
          "type": "string",
          "minLength": 1
        },
        "entry_plan_sha256": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "entry_plan_decision": {
          "enum": [
            "BLOCKED_NOT_READY",
            "READY_FOR_THOMAS_ENTRY_APPROVAL_DESIGN"
          ]
        }
      }
    },
    "adapter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "adapter_id",
        "adapter_version",
        "implementation_available",
        "enabled",
        "runtime_source_of_truth",
        "entry_call_allowed"
      ],
      "properties": {
        "adapter_id": {
          "const": "thomas.runtime_authoritative_read_only_entry.disabled"
        },
        "adapter_version": {
          "const": "0.1.0"
        },
        "implementation_available": {
          "const": true
        },
        "enabled": {
          "const": false
        },
        "runtime_source_of_truth": {
          "const": false
        },
        "entry_call_allowed": {
          "const": false
        }
      }
    },
    "checks": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "check_id",
          "result",
          "notes"
        ],
        "properties": {
          "check_id": {
            "type": "string",
            "minLength": 1
          },
          "result": {
            "const": "PASS"
          },
          "notes": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "result",
        "reason_codes",
        "entry_performed",
        "runtime_authoritative_session_started",
        "executor_handoff_performed",
        "approval_consumed"
      ],
      "properties": {
        "result": {
          "const": "BLOCKED_DISABLED_ENTRY_ADAPTER"
        },
        "reason_codes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "entry_performed": {
          "const": false
        },
        "runtime_authoritative_session_started": {
          "const": false
        },
        "executor_handoff_performed": {
          "const": false
        },
        "approval_consumed": {
          "const": false
        }
      }
    },
    "runtime_effect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "filesystem_write_performed",
        "model_invocation_performed",
        "tool_execution_performed",
        "program_execution_performed",
        "network_call_performed",
        "external_action_performed",
        "financial_action_performed",
        "runtime_mutation_performed",
        "approval_consumption_performed",
        "runtime_session_started",
        "executor_handoff_performed",
        "permission_expansion_performed",
        "authority_expansion_performed",
        "core_activation_performed"
      ],
      "properties": {
        "mode": {
          "const": "DISABLED_EVIDENCE_ONLY"
        },
        "filesystem_write_performed": {
          "const": false
        },
        "model_invocation_performed": {
          "const": false
        },
        "tool_execution_performed": {
          "const": false
        },
        "program_execution_performed": {
          "const": false
        },
        "network_call_performed": {
          "const": false
        },
        "external_action_performed": {
          "const": false
        },
        "financial_action_performed": {
          "const": false
        },
        "runtime_mutation_performed": {
          "const": false
        },
        "approval_consumption_performed": {
          "const": false
        },
        "runtime_session_started": {
          "const": false
        },
        "executor_handoff_performed": {
          "const": false
        },
        "permission_expansion_performed": {
          "const": false
        },
        "authority_expansion_performed": {
          "const": false
        },
        "core_activation_performed": {
          "const": false
        }
      }
    },
    "integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hash_schema",
        "evidence_fingerprint_payload",
        "evidence_sha256"
      ],
      "properties": {
        "hash_schema": {
          "const": "disabled_runtime_authoritative_read_only_entry_evidence_fingerprint_payload.v0.1"
        },
        "evidence_fingerprint_payload": {
          "type": "object"
        },
        "evidence_sha256": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
