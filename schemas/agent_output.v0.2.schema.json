{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agent_output.v0.2.schema.json",
  "title": "Thomas Agent Output v0.2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "agent_output_id",
    "trace_id",
    "task_id",
    "core_context_binding_id",
    "assignment_id",
    "actor_instance_id",
    "role_id",
    "role_version",
    "status",
    "goal",
    "summary",
    "facts",
    "evidence",
    "inferences",
    "assumptions",
    "uncertainty",
    "risks",
    "recommendation",
    "limitations",
    "validation_recommended",
    "permission_request_refs",
    "next_actions",
    "memory_candidates",
    "escalation_required",
    "role_specific_output",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "agent_output.v0.2"
    },
    "agent_output_id": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "core_context_binding_id": {
      "type": "string",
      "pattern": "^ccb-[A-Za-z0-9._:-]+$"
    },
    "assignment_id": {
      "type": "string",
      "minLength": 1
    },
    "actor_instance_id": {
      "type": "string",
      "minLength": 1
    },
    "role_id": {
      "type": "string",
      "minLength": 1
    },
    "role_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "status": {
      "enum": [
        "draft",
        "partial",
        "final",
        "needs_validation",
        "blocked",
        "failed",
        "input_required",
        "approval_required",
        "rejected"
      ]
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "facts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "statement",
          "evidence_refs"
        ],
        "properties": {
          "statement": {
            "type": "string",
            "minLength": 1
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          }
        }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "ref",
          "type"
        ],
        "properties": {
          "ref": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "inferences": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "statement"
        ],
        "properties": {
          "statement": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "uncertainty": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommendation": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "action",
        "reason"
      ],
      "properties": {
        "action": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validation_recommended": {
      "type": "boolean"
    },
    "permission_request_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "memory_candidates": {
      "type": "array"
    },
    "escalation_required": {
      "type": "boolean"
    },
    "role_specific_output": {
      "type": "object"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
