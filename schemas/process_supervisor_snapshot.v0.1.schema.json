{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "process_supervisor_snapshot.v0.1.schema.json",
  "title": "process_supervisor_snapshot.v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "snapshot_id",
    "status",
    "interface",
    "capabilities",
    "configured_services",
    "evidence",
    "runtime_effect",
    "created_at",
    "audit_refs"
  ],
  "properties": {
    "schema_version": {
      "const": "process_supervisor_snapshot.v0.1"
    },
    "snapshot_id": {
      "type": "string",
      "pattern": "^supersnap_[A-Za-z0-9._:-]+$"
    },
    "status": {
      "const": "REVIEW_ONLY_DISABLED"
    },
    "interface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "connected",
        "implementation_available",
        "runtime_source_of_truth",
        "process_observation_performed",
        "process_control_enabled"
      ],
      "properties": {
        "connected": {
          "const": false
        },
        "implementation_available": {
          "const": false
        },
        "runtime_source_of_truth": {
          "const": false
        },
        "process_observation_performed": {
          "const": false
        },
        "process_control_enabled": {
          "const": false
        }
      }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "start_allowed",
        "stop_allowed",
        "restart_allowed",
        "kill_allowed",
        "signal_allowed",
        "auto_restart_allowed"
      ],
      "properties": {
        "start_allowed": {
          "const": false
        },
        "stop_allowed": {
          "const": false
        },
        "restart_allowed": {
          "const": false
        },
        "kill_allowed": {
          "const": false
        },
        "signal_allowed": {
          "const": false
        },
        "auto_restart_allowed": {
          "const": false
        }
      }
    },
    "configured_services": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "service_id",
          "intended_purpose",
          "expected_process_type",
          "observed_status",
          "pid",
          "health_ref"
        ],
        "properties": {
          "service_id": {
            "type": "string",
            "minLength": 1
          },
          "intended_purpose": {
            "type": "string",
            "minLength": 1
          },
          "expected_process_type": {
            "enum": [
              "PYTHON_SERVICE",
              "SCHEDULER_SERVICE",
              "AGENT_RUNTIME",
              "VALIDATION_WORKER"
            ]
          },
          "observed_status": {
            "const": "NOT_OBSERVED"
          },
          "pid": {
            "type": "null"
          },
          "health_ref": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "source_refs",
        "live_process_data_included",
        "process_probe_performed"
      ],
      "properties": {
        "mode": {
          "const": "STATIC_DESIGN_ONLY"
        },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "live_process_data_included": {
          "const": false
        },
        "process_probe_performed": {
          "const": false
        }
      }
    },
    "runtime_effect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "control_channel_connected",
        "identity_binding_activated",
        "challenge_issued",
        "challenge_verified",
        "command_dispatched",
        "supervisor_connected",
        "process_control_enabled",
        "process_started",
        "process_stopped",
        "process_restarted",
        "process_killed",
        "scheduler_connected",
        "scheduler_job_installed",
        "scheduler_job_enabled",
        "scheduler_dispatch_performed",
        "task_created_by_scheduler",
        "monitoring_policy_activated",
        "alert_delivery_performed",
        "automatic_remediation_performed",
        "kill_switch_triggered",
        "sandbox_created",
        "sandbox_test_executed",
        "filesystem_write_performed",
        "network_call_performed",
        "subprocess_performed",
        "secret_access_performed",
        "executor_candidate_registered",
        "executor_registry_mutation_allowed",
        "executor_activation_allowed",
        "executor_handoff_allowed",
        "runtime_mutation_allowed",
        "external_execution_allowed",
        "financial_execution_allowed",
        "side_effects_allowed",
        "permission_expansion_allowed",
        "authority_expansion_allowed"
      ],
      "properties": {
        "mode": {
          "enum": [
            "REVIEW_ONLY",
            "EVIDENCE_ONLY",
            "PREVIEW_ONLY"
          ]
        },
        "control_channel_connected": {
          "const": false
        },
        "identity_binding_activated": {
          "const": false
        },
        "challenge_issued": {
          "const": false
        },
        "challenge_verified": {
          "const": false
        },
        "command_dispatched": {
          "const": false
        },
        "supervisor_connected": {
          "const": false
        },
        "process_control_enabled": {
          "const": false
        },
        "process_started": {
          "const": false
        },
        "process_stopped": {
          "const": false
        },
        "process_restarted": {
          "const": false
        },
        "process_killed": {
          "const": false
        },
        "scheduler_connected": {
          "const": false
        },
        "scheduler_job_installed": {
          "const": false
        },
        "scheduler_job_enabled": {
          "const": false
        },
        "scheduler_dispatch_performed": {
          "const": false
        },
        "task_created_by_scheduler": {
          "const": false
        },
        "monitoring_policy_activated": {
          "const": false
        },
        "alert_delivery_performed": {
          "const": false
        },
        "automatic_remediation_performed": {
          "const": false
        },
        "kill_switch_triggered": {
          "const": false
        },
        "sandbox_created": {
          "const": false
        },
        "sandbox_test_executed": {
          "const": false
        },
        "filesystem_write_performed": {
          "const": false
        },
        "network_call_performed": {
          "const": false
        },
        "subprocess_performed": {
          "const": false
        },
        "secret_access_performed": {
          "const": false
        },
        "executor_candidate_registered": {
          "const": false
        },
        "executor_registry_mutation_allowed": {
          "const": false
        },
        "executor_activation_allowed": {
          "const": false
        },
        "executor_handoff_allowed": {
          "const": false
        },
        "runtime_mutation_allowed": {
          "const": false
        },
        "external_execution_allowed": {
          "const": false
        },
        "financial_execution_allowed": {
          "const": false
        },
        "side_effects_allowed": {
          "const": false
        },
        "permission_expansion_allowed": {
          "const": false
        },
        "authority_expansion_allowed": {
          "const": false
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "audit_refs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
