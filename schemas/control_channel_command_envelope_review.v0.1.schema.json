{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "control_channel_command_envelope_review.v0.1.schema.json",
  "title": "control_channel_command_envelope_review.v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "command_envelope_review_id",
    "identity_binding_ref",
    "identity_binding_fingerprint",
    "message",
    "command",
    "authentication_review",
    "request_fingerprint_payload",
    "request_fingerprint",
    "decision",
    "effects",
    "runtime_effect",
    "audit_refs"
  ],
  "properties": {
    "schema_version": {
      "const": "control_channel_command_envelope_review.v0.1"
    },
    "command_envelope_review_id": {
      "type": "string",
      "pattern": "^cccmd_[A-Za-z0-9._:-]+$"
    },
    "identity_binding_ref": {
      "type": "string",
      "minLength": 1
    },
    "identity_binding_fingerprint": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "message": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "private_chat_claimed",
        "message_ref_fingerprint",
        "raw_message_content_included",
        "raw_user_id_included",
        "raw_chat_id_included",
        "forwarded",
        "reaction_only"
      ],
      "properties": {
        "provider": {
          "const": "telegram"
        },
        "private_chat_claimed": {
          "const": true
        },
        "message_ref_fingerprint": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "raw_message_content_included": {
          "const": false
        },
        "raw_user_id_included": {
          "const": false
        },
        "raw_chat_id_included": {
          "const": false
        },
        "forwarded": {
          "const": false
        },
        "reaction_only": {
          "const": false
        }
      }
    },
    "command": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "target_task_id",
        "approval_ref",
        "action_fingerprint_short_code"
      ],
      "properties": {
        "name": {
          "enum": [
            "PAUSE",
            "STOP_TASK",
            "KILL",
            "RESUME"
          ]
        },
        "target_task_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "approval_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "action_fingerprint_short_code": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "authentication_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "result",
        "binding_match",
        "identity_verified",
        "private_chat_verified",
        "freshness_verified",
        "replay_protection_verified",
        "exact_reference_verified"
      ],
      "properties": {
        "result": {
          "const": "NOT_RUNTIME_VERIFIED"
        },
        "binding_match": {
          "const": true
        },
        "identity_verified": {
          "const": false
        },
        "private_chat_verified": {
          "const": false
        },
        "freshness_verified": {
          "const": false
        },
        "replay_protection_verified": {
          "const": false
        },
        "exact_reference_verified": {
          "const": false
        }
      }
    },
    "request_fingerprint_payload": {
      "type": "object"
    },
    "request_fingerprint": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "result",
        "allowed_for_runtime",
        "reasons"
      ],
      "properties": {
        "result": {
          "const": "NOT_DISPATCHED_REVIEW_ONLY"
        },
        "allowed_for_runtime": {
          "const": false
        },
        "reasons": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "effects": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command_dispatched",
        "kill_switch_state_changed",
        "process_control_performed",
        "scheduler_changed",
        "approval_created",
        "approval_consumed",
        "execution_blocked",
        "resume_performed"
      ],
      "properties": {
        "command_dispatched": {
          "const": false
        },
        "kill_switch_state_changed": {
          "const": false
        },
        "process_control_performed": {
          "const": false
        },
        "scheduler_changed": {
          "const": false
        },
        "approval_created": {
          "const": false
        },
        "approval_consumed": {
          "const": false
        },
        "execution_blocked": {
          "const": false
        },
        "resume_performed": {
          "const": false
        }
      }
    },
    "runtime_effect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "control_channel_connected",
        "identity_binding_activated",
        "challenge_issued",
        "challenge_verified",
        "command_dispatched",
        "supervisor_connected",
        "process_control_enabled",
        "process_started",
        "process_stopped",
        "process_restarted",
        "process_killed",
        "scheduler_connected",
        "scheduler_job_installed",
        "scheduler_job_enabled",
        "scheduler_dispatch_performed",
        "task_created_by_scheduler",
        "monitoring_policy_activated",
        "alert_delivery_performed",
        "automatic_remediation_performed",
        "kill_switch_triggered",
        "sandbox_created",
        "sandbox_test_executed",
        "filesystem_write_performed",
        "network_call_performed",
        "subprocess_performed",
        "secret_access_performed",
        "executor_candidate_registered",
        "executor_registry_mutation_allowed",
        "executor_activation_allowed",
        "executor_handoff_allowed",
        "runtime_mutation_allowed",
        "external_execution_allowed",
        "financial_execution_allowed",
        "side_effects_allowed",
        "permission_expansion_allowed",
        "authority_expansion_allowed"
      ],
      "properties": {
        "mode": {
          "enum": [
            "REVIEW_ONLY",
            "EVIDENCE_ONLY",
            "PREVIEW_ONLY"
          ]
        },
        "control_channel_connected": {
          "const": false
        },
        "identity_binding_activated": {
          "const": false
        },
        "challenge_issued": {
          "const": false
        },
        "challenge_verified": {
          "const": false
        },
        "command_dispatched": {
          "const": false
        },
        "supervisor_connected": {
          "const": false
        },
        "process_control_enabled": {
          "const": false
        },
        "process_started": {
          "const": false
        },
        "process_stopped": {
          "const": false
        },
        "process_restarted": {
          "const": false
        },
        "process_killed": {
          "const": false
        },
        "scheduler_connected": {
          "const": false
        },
        "scheduler_job_installed": {
          "const": false
        },
        "scheduler_job_enabled": {
          "const": false
        },
        "scheduler_dispatch_performed": {
          "const": false
        },
        "task_created_by_scheduler": {
          "const": false
        },
        "monitoring_policy_activated": {
          "const": false
        },
        "alert_delivery_performed": {
          "const": false
        },
        "automatic_remediation_performed": {
          "const": false
        },
        "kill_switch_triggered": {
          "const": false
        },
        "sandbox_created": {
          "const": false
        },
        "sandbox_test_executed": {
          "const": false
        },
        "filesystem_write_performed": {
          "const": false
        },
        "network_call_performed": {
          "const": false
        },
        "subprocess_performed": {
          "const": false
        },
        "secret_access_performed": {
          "const": false
        },
        "executor_candidate_registered": {
          "const": false
        },
        "executor_registry_mutation_allowed": {
          "const": false
        },
        "executor_activation_allowed": {
          "const": false
        },
        "executor_handoff_allowed": {
          "const": false
        },
        "runtime_mutation_allowed": {
          "const": false
        },
        "external_execution_allowed": {
          "const": false
        },
        "financial_execution_allowed": {
          "const": false
        },
        "side_effects_allowed": {
          "const": false
        },
        "permission_expansion_allowed": {
          "const": false
        },
        "authority_expansion_allowed": {
          "const": false
        }
      }
    },
    "audit_refs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "command": {
            "properties": {
              "name": {
                "const": "STOP_TASK"
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "command": {
            "properties": {
              "target_task_id": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      },
      "else": {
        "properties": {
          "command": {
            "properties": {
              "target_task_id": {
                "type": "null"
              }
            }
          }
        }
      }
    }
  ]
}
