{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "local_reversible_sandbox_candidate_test_review.v0.1.schema.json",
  "title": "local_reversible_sandbox_candidate_test_review.v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "review_id",
    "test_plan_ref",
    "test_plan_fingerprint",
    "checks",
    "summary",
    "execution_evidence",
    "runtime_effect",
    "created_at",
    "audit_refs"
  ],
  "properties": {
    "schema_version": {
      "const": "local_reversible_sandbox_candidate_test_review.v0.1"
    },
    "review_id": {
      "type": "string",
      "pattern": "^sandreview_[A-Za-z0-9._:-]+$"
    },
    "test_plan_ref": {
      "type": "string",
      "minLength": 1
    },
    "test_plan_fingerprint": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "checks": {
      "type": "array",
      "minItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "check_id",
          "status",
          "evidence_refs",
          "reason"
        ],
        "properties": {
          "check_id": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "enum": [
              "PASS",
              "FAIL",
              "NOT_AVAILABLE"
            ]
          },
          "evidence_refs": {
            "type": "array",
            "minItems": 0,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "result",
        "passed_check_count",
        "failed_check_count",
        "unavailable_check_count",
        "missing_prerequisites",
        "accepted_for_review_backlog",
        "ready_for_test_authorization",
        "ready_for_registry_candidate_record",
        "ready_for_activation_review",
        "ready_for_executor_handoff"
      ],
      "properties": {
        "result": {
          "const": "NOT_RUN_NOT_READY"
        },
        "passed_check_count": {
          "type": "integer",
          "minimum": 0
        },
        "failed_check_count": {
          "type": "integer",
          "minimum": 0
        },
        "unavailable_check_count": {
          "type": "integer",
          "minimum": 0
        },
        "missing_prerequisites": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "accepted_for_review_backlog": {
          "const": true
        },
        "ready_for_test_authorization": {
          "const": false
        },
        "ready_for_registry_candidate_record": {
          "const": false
        },
        "ready_for_activation_review": {
          "const": false
        },
        "ready_for_executor_handoff": {
          "const": false
        }
      }
    },
    "execution_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sandbox_created",
        "test_execution_started",
        "test_execution_completed",
        "filesystem_write_performed",
        "rollback_performed",
        "cleanup_performed",
        "network_call_performed",
        "subprocess_performed",
        "secret_access_performed"
      ],
      "properties": {
        "sandbox_created": {
          "const": false
        },
        "test_execution_started": {
          "const": false
        },
        "test_execution_completed": {
          "const": false
        },
        "filesystem_write_performed": {
          "const": false
        },
        "rollback_performed": {
          "const": false
        },
        "cleanup_performed": {
          "const": false
        },
        "network_call_performed": {
          "const": false
        },
        "subprocess_performed": {
          "const": false
        },
        "secret_access_performed": {
          "const": false
        }
      }
    },
    "runtime_effect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "control_channel_connected",
        "identity_binding_activated",
        "challenge_issued",
        "challenge_verified",
        "command_dispatched",
        "supervisor_connected",
        "process_control_enabled",
        "process_started",
        "process_stopped",
        "process_restarted",
        "process_killed",
        "scheduler_connected",
        "scheduler_job_installed",
        "scheduler_job_enabled",
        "scheduler_dispatch_performed",
        "task_created_by_scheduler",
        "monitoring_policy_activated",
        "alert_delivery_performed",
        "automatic_remediation_performed",
        "kill_switch_triggered",
        "sandbox_created",
        "sandbox_test_executed",
        "filesystem_write_performed",
        "network_call_performed",
        "subprocess_performed",
        "secret_access_performed",
        "executor_candidate_registered",
        "executor_registry_mutation_allowed",
        "executor_activation_allowed",
        "executor_handoff_allowed",
        "runtime_mutation_allowed",
        "external_execution_allowed",
        "financial_execution_allowed",
        "side_effects_allowed",
        "permission_expansion_allowed",
        "authority_expansion_allowed"
      ],
      "properties": {
        "mode": {
          "enum": [
            "REVIEW_ONLY",
            "EVIDENCE_ONLY",
            "PREVIEW_ONLY"
          ]
        },
        "control_channel_connected": {
          "const": false
        },
        "identity_binding_activated": {
          "const": false
        },
        "challenge_issued": {
          "const": false
        },
        "challenge_verified": {
          "const": false
        },
        "command_dispatched": {
          "const": false
        },
        "supervisor_connected": {
          "const": false
        },
        "process_control_enabled": {
          "const": false
        },
        "process_started": {
          "const": false
        },
        "process_stopped": {
          "const": false
        },
        "process_restarted": {
          "const": false
        },
        "process_killed": {
          "const": false
        },
        "scheduler_connected": {
          "const": false
        },
        "scheduler_job_installed": {
          "const": false
        },
        "scheduler_job_enabled": {
          "const": false
        },
        "scheduler_dispatch_performed": {
          "const": false
        },
        "task_created_by_scheduler": {
          "const": false
        },
        "monitoring_policy_activated": {
          "const": false
        },
        "alert_delivery_performed": {
          "const": false
        },
        "automatic_remediation_performed": {
          "const": false
        },
        "kill_switch_triggered": {
          "const": false
        },
        "sandbox_created": {
          "const": false
        },
        "sandbox_test_executed": {
          "const": false
        },
        "filesystem_write_performed": {
          "const": false
        },
        "network_call_performed": {
          "const": false
        },
        "subprocess_performed": {
          "const": false
        },
        "secret_access_performed": {
          "const": false
        },
        "executor_candidate_registered": {
          "const": false
        },
        "executor_registry_mutation_allowed": {
          "const": false
        },
        "executor_activation_allowed": {
          "const": false
        },
        "executor_handoff_allowed": {
          "const": false
        },
        "runtime_mutation_allowed": {
          "const": false
        },
        "external_execution_allowed": {
          "const": false
        },
        "financial_execution_allowed": {
          "const": false
        },
        "side_effects_allowed": {
          "const": false
        },
        "permission_expansion_allowed": {
          "const": false
        },
        "authority_expansion_allowed": {
          "const": false
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "audit_refs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
