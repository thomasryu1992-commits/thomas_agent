{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tool_request.v0.1.schema.json",
  "title": "Thomas Tool Request v0.1 Review-Only",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "tool_request_id",
    "trace_id",
    "task_id",
    "task_revision",
    "core_context_binding_id",
    "operating_policy",
    "requested_by",
    "role_scope",
    "resource",
    "operation",
    "authority",
    "permission",
    "budget",
    "validation",
    "request_fingerprint_payload",
    "request_fingerprint",
    "runtime_effect",
    "lifecycle",
    "audit_refs"
  ],
  "properties": {
    "schema_version": {
      "const": "tool_request.v0.1"
    },
    "tool_request_id": {
      "type": "string",
      "pattern": "^toolreq_[A-Za-z0-9._:-]+$"
    },
    "trace_id": {
      "type": "string",
      "pattern": "^trace_[A-Za-z0-9._-]+$"
    },
    "task_id": {
      "type": "string",
      "pattern": "^task_[A-Za-z0-9._-]+$"
    },
    "task_revision": {
      "type": "integer",
      "minimum": 1
    },
    "core_context_binding_id": {
      "type": "string",
      "pattern": "^ccb-[A-Za-z0-9._:-]+$"
    },
    "operating_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_id",
        "policy_version",
        "policy_ref"
      ],
      "properties": {
        "policy_id": {
          "const": "thomas.permission_approval.operating_policy"
        },
        "policy_version": {
          "const": "0.1.0"
        },
        "policy_ref": {
          "const": "docs/runtime-contracts/THOMAS_PERMISSION_APPROVAL_OPERATING_POLICY_V0.1.yaml"
        }
      }
    },
    "requested_by": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "actor_type",
        "actor_id",
        "role_id",
        "role_version",
        "assignment_id"
      ],
      "properties": {
        "actor_type": {
          "enum": [
            "thomas_prime",
            "role",
            "system"
          ]
        },
        "actor_id": {
          "type": "string",
          "minLength": 1
        },
        "role_id": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "role_version": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "assignment_id": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      }
    },
    "role_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role_definition_ref",
        "role_assignment_ref",
        "role_definition_resource_allowlisted",
        "assignment_resource_allowlisted"
      ],
      "properties": {
        "role_definition_ref": {
          "type": "string",
          "minLength": 1
        },
        "role_assignment_ref": {
          "type": "string",
          "minLength": 1
        },
        "role_definition_resource_allowlisted": {
          "type": "boolean"
        },
        "assignment_resource_allowlisted": {
          "type": "boolean"
        }
      }
    },
    "resource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tool_id",
        "tool_version",
        "registry_ref",
        "registry_status",
        "registry_enabled",
        "runtime_implementation_available",
        "tool_class",
        "external_action",
        "required_permission_level"
      ],
      "properties": {
        "tool_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.:-]*$"
        },
        "tool_version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "registry_ref": {
          "const": "05_REGISTRIES/TOOL_REGISTRY.yaml"
        },
        "registry_status": {
          "enum": [
            "draft",
            "candidate",
            "active",
            "disabled",
            "deprecated",
            "archived",
            "unregistered"
          ]
        },
        "registry_enabled": {
          "type": "boolean"
        },
        "runtime_implementation_available": {
          "type": "boolean"
        },
        "tool_class": {
          "enum": [
            "read",
            "analysis",
            "creation",
            "modification",
            "external_action",
            "destructive",
            "privileged"
          ]
        },
        "external_action": {
          "type": "boolean"
        },
        "required_permission_level": {
          "enum": [
            "P0",
            "P1",
            "P2",
            "P3",
            "P4",
            "P5",
            "P6"
          ]
        }
      }
    },
    "operation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operation_type",
        "permission_scope",
        "target_ref",
        "data_scope",
        "input_refs",
        "input_sha256",
        "content_sha256",
        "normalized_parameters",
        "purpose",
        "expected_result_contract"
      ],
      "properties": {
        "operation_type": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.:-]*$"
        },
        "permission_scope": {
          "enum": [
            "INTERNAL_READ",
            "INTERNAL_ANALYSIS",
            "DRAFT_CREATION",
            "SIMULATION_VALIDATION",
            "REVIEW_PACKET_CREATION",
            "CANDIDATE_CREATION",
            "CONTROL_CHANNEL_RESPONSE",
            "WORKSPACE_REVERSIBLE_WRITE",
            "GIT_AGENT_BRANCH_CHANGE",
            "LOCAL_BUILD_TEST",
            "LOW_RISK_OPERATIONAL_KNOWLEDGE",
            "FINANCIAL_APPROVED_BUDGET_USE",
            "EXTERNAL_COMMUNICATION",
            "PUBLICATION",
            "PROTECTED_BRANCH_CHANGE",
            "RELEASE_DEPLOYMENT",
            "FINANCIAL_NEW_COMMITMENT",
            "RUNTIME_GOVERNANCE",
            "DESTRUCTIVE_CHANGE",
            "ROLE_GOVERNANCE",
            "TOOL_PROGRAM_GOVERNANCE",
            "CANDIDATE_ROLE_TRIAL",
            "SENSITIVE_MEMORY_GOVERNANCE",
            "SECURITY_SENSITIVE_CHANGE",
            "AUTHORITY_ESCALATION",
            "SELF_APPROVAL",
            "APPROVAL_REUSE",
            "SECRET_EXFILTRATION",
            "AUDIT_TAMPERING",
            "KILL_SWITCH_BYPASS",
            "UNREGISTERED_RESOURCE_EXECUTION",
            "DISABLED_RESOURCE_EXECUTION",
            "PROTECTED_BRANCH_FORCE_PUSH"
          ]
        },
        "target_ref": {
          "type": "string",
          "minLength": 1
        },
        "data_scope": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "input_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "input_sha256": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^sha256:[0-9a-f]{64}$"
          },
          "uniqueItems": true
        },
        "content_sha256": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "normalized_parameters": {
          "type": "object"
        },
        "purpose": {
          "type": "string",
          "minLength": 1
        },
        "expected_result_contract": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "request_required_permission_level",
        "resource_required_permission_level",
        "role_permission_ceiling",
        "assignment_granted_permission_level",
        "effective_permission_level",
        "authority_sufficient",
        "authority_reasons"
      ],
      "properties": {
        "request_required_permission_level": {
          "enum": [
            "P0",
            "P1",
            "P2",
            "P3",
            "P4",
            "P5",
            "P6"
          ]
        },
        "resource_required_permission_level": {
          "enum": [
            "P0",
            "P1",
            "P2",
            "P3",
            "P4",
            "P5",
            "P6"
          ]
        },
        "role_permission_ceiling": {
          "enum": [
            "P0",
            "P1",
            "P2",
            "P3",
            "P4",
            "P5",
            "P6"
          ]
        },
        "assignment_granted_permission_level": {
          "enum": [
            "P0",
            "P1",
            "P2",
            "P3",
            "P4",
            "P5",
            "P6"
          ]
        },
        "effective_permission_level": {
          "enum": [
            "P0",
            "P1",
            "P2",
            "P3",
            "P4",
            "P5",
            "P6"
          ]
        },
        "authority_sufficient": {
          "type": "boolean"
        },
        "authority_reasons": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        }
      }
    },
    "permission": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "permission_decision_ref",
        "permission_decision_id",
        "permission_decision",
        "action_fingerprint",
        "approval_id",
        "binding_verified"
      ],
      "properties": {
        "permission_decision_ref": {
          "type": "string",
          "minLength": 1
        },
        "permission_decision_id": {
          "type": "string",
          "pattern": "^permdec_[A-Za-z0-9._:-]+$"
        },
        "permission_decision": {
          "enum": [
            "ALLOW",
            "EXECUTE_AND_REPORT",
            "APPROVAL_REQUIRED",
            "BLOCK"
          ]
        },
        "action_fingerprint": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "approval_id": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "binding_verified": {
          "type": "boolean"
        }
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "assignment_budget_ref",
        "requested_call_count",
        "remaining_call_count",
        "requested_runtime_seconds",
        "remaining_runtime_seconds",
        "requested_cost_decimal",
        "remaining_cost_decimal",
        "cost_currency",
        "within_assignment_budget"
      ],
      "properties": {
        "assignment_budget_ref": {
          "type": "string",
          "minLength": 1
        },
        "requested_call_count": {
          "type": "integer",
          "minimum": 1
        },
        "remaining_call_count": {
          "type": "integer",
          "minimum": 0
        },
        "requested_runtime_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "remaining_runtime_seconds": {
          "type": "integer",
          "minimum": 0
        },
        "requested_cost_decimal": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^(0|[1-9][0-9]*)(\\.[0-9]+)?$"
        },
        "remaining_cost_decimal": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^(0|[1-9][0-9]*)(\\.[0-9]+)?$"
        },
        "cost_currency": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[A-Z]{3,12}$"
        },
        "within_assignment_budget": {
          "type": "boolean"
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "registry_match",
        "registry_runtime_eligible",
        "role_definition_allowlist_match",
        "assignment_allowlist_match",
        "policy_scope_match",
        "permission_binding_match",
        "budget_within_limit",
        "lineage_complete",
        "review_result",
        "block_reasons"
      ],
      "properties": {
        "registry_match": {
          "type": "boolean"
        },
        "registry_runtime_eligible": {
          "type": "boolean"
        },
        "role_definition_allowlist_match": {
          "type": "boolean"
        },
        "assignment_allowlist_match": {
          "type": "boolean"
        },
        "policy_scope_match": {
          "type": "boolean"
        },
        "permission_binding_match": {
          "type": "boolean"
        },
        "budget_within_limit": {
          "type": "boolean"
        },
        "lineage_complete": {
          "type": "boolean"
        },
        "review_result": {
          "enum": [
            "REVIEW_READY",
            "BLOCK"
          ]
        },
        "block_reasons": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "request_fingerprint_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "resource_type",
        "task_id",
        "task_revision",
        "core_context_binding_id",
        "requester_ref",
        "resource_id",
        "resource_version",
        "operation_type",
        "permission_scope",
        "target_ref",
        "data_scope",
        "input_refs",
        "input_sha256",
        "content_sha256",
        "normalized_parameters",
        "assignment_budget_ref",
        "expires_at"
      ],
      "properties": {
        "schema_version": {
          "const": "resource_request_fingerprint_payload.v0.1"
        },
        "resource_type": {
          "enum": [
            "TOOL",
            "PROGRAM"
          ]
        },
        "task_id": {
          "type": "string",
          "pattern": "^task_[A-Za-z0-9._-]+$"
        },
        "task_revision": {
          "type": "integer",
          "minimum": 1
        },
        "core_context_binding_id": {
          "type": "string",
          "pattern": "^ccb-[A-Za-z0-9._:-]+$"
        },
        "requester_ref": {
          "type": "string",
          "minLength": 1
        },
        "resource_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.:-]*$"
        },
        "resource_version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "operation_type": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.:-]*$"
        },
        "permission_scope": {
          "enum": [
            "INTERNAL_READ",
            "INTERNAL_ANALYSIS",
            "DRAFT_CREATION",
            "SIMULATION_VALIDATION",
            "REVIEW_PACKET_CREATION",
            "CANDIDATE_CREATION",
            "CONTROL_CHANNEL_RESPONSE",
            "WORKSPACE_REVERSIBLE_WRITE",
            "GIT_AGENT_BRANCH_CHANGE",
            "LOCAL_BUILD_TEST",
            "LOW_RISK_OPERATIONAL_KNOWLEDGE",
            "FINANCIAL_APPROVED_BUDGET_USE",
            "EXTERNAL_COMMUNICATION",
            "PUBLICATION",
            "PROTECTED_BRANCH_CHANGE",
            "RELEASE_DEPLOYMENT",
            "FINANCIAL_NEW_COMMITMENT",
            "RUNTIME_GOVERNANCE",
            "DESTRUCTIVE_CHANGE",
            "ROLE_GOVERNANCE",
            "TOOL_PROGRAM_GOVERNANCE",
            "CANDIDATE_ROLE_TRIAL",
            "SENSITIVE_MEMORY_GOVERNANCE",
            "SECURITY_SENSITIVE_CHANGE",
            "AUTHORITY_ESCALATION",
            "SELF_APPROVAL",
            "APPROVAL_REUSE",
            "SECRET_EXFILTRATION",
            "AUDIT_TAMPERING",
            "KILL_SWITCH_BYPASS",
            "UNREGISTERED_RESOURCE_EXECUTION",
            "DISABLED_RESOURCE_EXECUTION",
            "PROTECTED_BRANCH_FORCE_PUSH"
          ]
        },
        "target_ref": {
          "type": "string",
          "minLength": 1
        },
        "data_scope": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "input_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "input_sha256": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^sha256:[0-9a-f]{64}$"
          },
          "uniqueItems": true
        },
        "content_sha256": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "normalized_parameters": {
          "type": "object"
        },
        "assignment_budget_ref": {
          "type": "string",
          "minLength": 1
        },
        "expires_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "request_fingerprint": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "runtime_effect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "request_record_can_execute",
        "executor_handoff_allowed",
        "tool_execution_allowed",
        "program_execution_allowed",
        "resource_enablement_allowed",
        "registry_mutation_allowed",
        "runtime_mutation_allowed",
        "external_execution_allowed",
        "financial_execution_allowed",
        "permission_expansion_allowed"
      ],
      "properties": {
        "mode": {
          "const": "REVIEW_ONLY"
        },
        "request_record_can_execute": {
          "const": false
        },
        "executor_handoff_allowed": {
          "const": false
        },
        "tool_execution_allowed": {
          "const": false
        },
        "program_execution_allowed": {
          "const": false
        },
        "resource_enablement_allowed": {
          "const": false
        },
        "registry_mutation_allowed": {
          "const": false
        },
        "runtime_mutation_allowed": {
          "const": false
        },
        "external_execution_allowed": {
          "const": false
        },
        "financial_execution_allowed": {
          "const": false
        },
        "permission_expansion_allowed": {
          "const": false
        }
      }
    },
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "review_status",
        "created_at",
        "expires_at",
        "supersedes"
      ],
      "properties": {
        "review_status": {
          "enum": [
            "REVIEW_READY",
            "BLOCKED",
            "SUPERSEDED",
            "CANCELED"
          ]
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "expires_at": {
          "type": "string",
          "format": "date-time"
        },
        "supersedes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "audit_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "validation": {
            "properties": {
              "review_result": {
                "const": "BLOCK"
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "lifecycle": {
            "properties": {
              "review_status": {
                "const": "BLOCKED"
              }
            }
          },
          "permission": {
            "properties": {
              "permission_decision": {
                "const": "BLOCK"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "validation": {
            "properties": {
              "review_result": {
                "const": "REVIEW_READY"
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "lifecycle": {
            "properties": {
              "review_status": {
                "const": "REVIEW_READY"
              }
            }
          },
          "validation": {
            "properties": {
              "block_reasons": {
                "maxItems": 0
              }
            }
          }
        }
      }
    }
  ]
}
