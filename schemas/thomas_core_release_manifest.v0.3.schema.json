{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "thomas_core_release_manifest.v0.3.schema.json",
  "title": "Thomas Core Release Manifest v0.3.1 Lean",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "manifest_version",
    "release_id",
    "core_version",
    "release_status",
    "runtime_use_allowed_without_separate_approval",
    "owner",
    "hash_algorithm",
    "core_bundle_sha256",
    "historical_verification",
    "canonical_artifacts",
    "active_runtime",
    "files",
    "build",
    "approval_requirement",
    "immutability",
    "runtime_binding"
  ],
  "properties": {
    "schema_version": {
      "const": "thomas_core_release_manifest.v0.3"
    },
    "manifest_version": {
      "const": "0.3.1"
    },
    "release_id": {
      "type": "string",
      "pattern": "^thomas-core-v\\d+\\.\\d+\\.\\d+-[0-9a-f]{12}$"
    },
    "core_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "release_status": {
      "const": "review_ready"
    },
    "runtime_use_allowed_without_separate_approval": {
      "const": false
    },
    "owner": {
      "const": "Thomas"
    },
    "hash_algorithm": {
      "const": "sha256"
    },
    "core_bundle_sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "historical_verification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "uses_release_snapshot",
        "uses_current_worktree",
        "artifact_snapshot_root",
        "toolchain_snapshot_root"
      ],
      "properties": {
        "uses_release_snapshot": {
          "const": true
        },
        "uses_current_worktree": {
          "const": false
        },
        "artifact_snapshot_root": {
          "const": "artifacts"
        },
        "toolchain_snapshot_root": {
          "const": "validation_toolchain"
        }
      }
    },
    "canonical_artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "philosophy",
        "active_core",
        "runtime_policy_projection"
      ],
      "properties": {
        "philosophy": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "logical_path",
            "snapshot_path",
            "sha256"
          ],
          "properties": {
            "logical_path": {
              "type": "string",
              "minLength": 1
            },
            "snapshot_path": {
              "type": "string",
              "minLength": 1
            },
            "sha256": {
              "type": "string",
              "pattern": "^sha256:[0-9a-f]{64}$"
            }
          }
        },
        "active_core": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "logical_path",
            "snapshot_path",
            "sha256"
          ],
          "properties": {
            "logical_path": {
              "type": "string",
              "minLength": 1
            },
            "snapshot_path": {
              "type": "string",
              "minLength": 1
            },
            "sha256": {
              "type": "string",
              "pattern": "^sha256:[0-9a-f]{64}$"
            }
          }
        },
        "runtime_policy_projection": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "logical_path",
            "snapshot_path",
            "sha256"
          ],
          "properties": {
            "logical_path": {
              "type": "string",
              "minLength": 1
            },
            "snapshot_path": {
              "type": "string",
              "minLength": 1
            },
            "sha256": {
              "type": "string",
              "pattern": "^sha256:[0-9a-f]{64}$"
            }
          }
        }
      }
    },
    "active_runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "active_rule_ids",
        "active_rule_count",
        "projection_map_version"
      ],
      "properties": {
        "active_rule_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^MVP_RULE_[0-9]{3}$"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "active_rule_count": {
          "type": "integer",
          "minimum": 1
        },
        "projection_map_version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "logical_path",
          "snapshot_path",
          "sha256",
          "size_bytes"
        ],
        "properties": {
          "logical_path": {
            "type": "string",
            "minLength": 1
          },
          "snapshot_path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^sha256:[0-9a-f]{64}$"
          },
          "size_bytes": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    },
    "build": {
      "type": "object"
    },
    "approval_requirement": {
      "type": "object"
    },
    "immutability": {
      "type": "object"
    },
    "runtime_binding": {
      "type": "object"
    }
  }
}
