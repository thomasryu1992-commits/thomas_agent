{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "disabled_executor_evidence.v0.1.schema.json",
  "title": "Disabled Restricted Execution Service Evidence v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "evidence_id",
    "execution_request_id",
    "execution_request_ref",
    "execution_request_fingerprint",
    "service",
    "decision",
    "effects",
    "runtime_effect",
    "created_at",
    "audit_refs"
  ],
  "properties": {
    "schema_version": {
      "const": "disabled_executor_evidence.v0.1"
    },
    "evidence_id": {
      "pattern": "^disexevidence_[A-Za-z0-9._:-]+$",
      "type": "string"
    },
    "execution_request_id": {
      "type": "string",
      "minLength": 1
    },
    "execution_request_ref": {
      "type": "string",
      "minLength": 1
    },
    "execution_request_fingerprint": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "service_id",
        "service_version",
        "status",
        "implementation_mode",
        "network_clients_present",
        "external_adapters_present",
        "secret_reader_present",
        "subprocess_runner_present"
      ],
      "properties": {
        "service_id": {
          "const": "restricted.execution.service.disabled"
        },
        "service_version": {
          "const": "0.1.0"
        },
        "status": {
          "const": "DISABLED"
        },
        "implementation_mode": {
          "const": "EVIDENCE_ONLY"
        },
        "network_clients_present": {
          "const": false
        },
        "external_adapters_present": {
          "const": false
        },
        "secret_reader_present": {
          "const": false
        },
        "subprocess_runner_present": {
          "const": false
        }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "result",
        "reason_codes",
        "message"
      ],
      "properties": {
        "result": {
          "const": "BLOCKED_DISABLED_SERVICE"
        },
        "reason_codes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "message": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "effects": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "execution_performed",
        "executor_called",
        "tool_execution_performed",
        "program_execution_performed",
        "approval_consumed",
        "external_side_effect_performed",
        "financial_side_effect_performed",
        "runtime_mutation_performed",
        "files_mutated",
        "network_calls"
      ],
      "properties": {
        "execution_performed": {
          "const": false
        },
        "executor_called": {
          "const": false
        },
        "tool_execution_performed": {
          "const": false
        },
        "program_execution_performed": {
          "const": false
        },
        "approval_consumed": {
          "const": false
        },
        "external_side_effect_performed": {
          "const": false
        },
        "financial_side_effect_performed": {
          "const": false
        },
        "runtime_mutation_performed": {
          "const": false
        },
        "files_mutated": {
          "type": "array",
          "maxItems": 0
        },
        "network_calls": {
          "type": "integer",
          "const": 0
        }
      }
    },
    "runtime_effect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "executor_registration_allowed",
        "executor_activation_allowed",
        "executor_handoff_allowed",
        "executor_call_allowed",
        "tool_execution_allowed",
        "program_execution_allowed",
        "approval_consumption_allowed",
        "external_execution_allowed",
        "financial_execution_allowed",
        "runtime_mutation_allowed",
        "side_effects_allowed",
        "permission_expansion_allowed",
        "authority_expansion_allowed"
      ],
      "properties": {
        "mode": {
          "enum": [
            "REVIEW_ONLY",
            "EVIDENCE_ONLY",
            "PREVIEW_ONLY"
          ]
        },
        "executor_registration_allowed": {
          "const": false
        },
        "executor_activation_allowed": {
          "const": false
        },
        "executor_handoff_allowed": {
          "const": false
        },
        "executor_call_allowed": {
          "const": false
        },
        "tool_execution_allowed": {
          "const": false
        },
        "program_execution_allowed": {
          "const": false
        },
        "approval_consumption_allowed": {
          "const": false
        },
        "external_execution_allowed": {
          "const": false
        },
        "financial_execution_allowed": {
          "const": false
        },
        "runtime_mutation_allowed": {
          "const": false
        },
        "side_effects_allowed": {
          "const": false
        },
        "permission_expansion_allowed": {
          "const": false
        },
        "authority_expansion_allowed": {
          "const": false
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "audit_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
