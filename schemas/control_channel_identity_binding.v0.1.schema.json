{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "control_channel_identity_binding.v0.1.schema.json",
  "title": "control_channel_identity_binding.v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "binding_id",
    "owner",
    "status",
    "channel",
    "identity",
    "verification",
    "command_policy",
    "binding_fingerprint_payload",
    "binding_fingerprint",
    "runtime_effect",
    "created_at",
    "expires_at",
    "audit_refs"
  ],
  "properties": {
    "schema_version": {
      "const": "control_channel_identity_binding.v0.1"
    },
    "binding_id": {
      "type": "string",
      "pattern": "^ccbind_[A-Za-z0-9._:-]+$"
    },
    "owner": {
      "const": "Thomas"
    },
    "status": {
      "const": "REVIEW_ONLY_UNBOUND"
    },
    "channel": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "channel_type",
        "channel_ref_fingerprint",
        "raw_channel_id_included",
        "bot_token_value_included",
        "webhook_secret_value_included",
        "private_chat_required",
        "group_allowed",
        "channel_allowed"
      ],
      "properties": {
        "provider": {
          "const": "telegram"
        },
        "channel_type": {
          "const": "TELEGRAM_PRIVATE_CHAT"
        },
        "channel_ref_fingerprint": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "raw_channel_id_included": {
          "const": false
        },
        "bot_token_value_included": {
          "const": false
        },
        "webhook_secret_value_included": {
          "const": false
        },
        "private_chat_required": {
          "const": true
        },
        "group_allowed": {
          "const": false
        },
        "channel_allowed": {
          "const": false
        }
      }
    },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "subject_type",
        "subject_id",
        "user_ref_fingerprint",
        "raw_user_id_included",
        "credential_values_included"
      ],
      "properties": {
        "subject_type": {
          "const": "real_thomas"
        },
        "subject_id": {
          "const": "Thomas"
        },
        "user_ref_fingerprint": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "raw_user_id_included": {
          "const": false
        },
        "credential_values_included": {
          "const": false
        }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "status",
        "evidence_refs",
        "control_channel_connected",
        "challenge_issued",
        "challenge_verified"
      ],
      "properties": {
        "mode": {
          "const": "REVIEW_ONLY_METADATA"
        },
        "status": {
          "const": "NOT_RUNTIME_VERIFIED"
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 0,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "control_channel_connected": {
          "const": false
        },
        "challenge_issued": {
          "const": false
        },
        "challenge_verified": {
          "const": false
        }
      }
    },
    "command_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowed_commands",
        "forwarded_message_allowed",
        "reaction_only_allowed",
        "ambiguous_text_allowed",
        "exact_reference_required",
        "resume_requires_fresh_runtime_verification"
      ],
      "properties": {
        "allowed_commands": {
          "type": "array",
          "minItems": 4,
          "uniqueItems": true,
          "items": {
            "enum": [
              "PAUSE",
              "STOP_TASK",
              "KILL",
              "RESUME"
            ]
          }
        },
        "forwarded_message_allowed": {
          "const": false
        },
        "reaction_only_allowed": {
          "const": false
        },
        "ambiguous_text_allowed": {
          "const": false
        },
        "exact_reference_required": {
          "const": true
        },
        "resume_requires_fresh_runtime_verification": {
          "const": true
        }
      }
    },
    "binding_fingerprint_payload": {
      "type": "object"
    },
    "binding_fingerprint": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "runtime_effect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "control_channel_connected",
        "identity_binding_activated",
        "challenge_issued",
        "challenge_verified",
        "command_dispatched",
        "supervisor_connected",
        "process_control_enabled",
        "process_started",
        "process_stopped",
        "process_restarted",
        "process_killed",
        "scheduler_connected",
        "scheduler_job_installed",
        "scheduler_job_enabled",
        "scheduler_dispatch_performed",
        "task_created_by_scheduler",
        "monitoring_policy_activated",
        "alert_delivery_performed",
        "automatic_remediation_performed",
        "kill_switch_triggered",
        "sandbox_created",
        "sandbox_test_executed",
        "filesystem_write_performed",
        "network_call_performed",
        "subprocess_performed",
        "secret_access_performed",
        "executor_candidate_registered",
        "executor_registry_mutation_allowed",
        "executor_activation_allowed",
        "executor_handoff_allowed",
        "runtime_mutation_allowed",
        "external_execution_allowed",
        "financial_execution_allowed",
        "side_effects_allowed",
        "permission_expansion_allowed",
        "authority_expansion_allowed"
      ],
      "properties": {
        "mode": {
          "enum": [
            "REVIEW_ONLY",
            "EVIDENCE_ONLY",
            "PREVIEW_ONLY"
          ]
        },
        "control_channel_connected": {
          "const": false
        },
        "identity_binding_activated": {
          "const": false
        },
        "challenge_issued": {
          "const": false
        },
        "challenge_verified": {
          "const": false
        },
        "command_dispatched": {
          "const": false
        },
        "supervisor_connected": {
          "const": false
        },
        "process_control_enabled": {
          "const": false
        },
        "process_started": {
          "const": false
        },
        "process_stopped": {
          "const": false
        },
        "process_restarted": {
          "const": false
        },
        "process_killed": {
          "const": false
        },
        "scheduler_connected": {
          "const": false
        },
        "scheduler_job_installed": {
          "const": false
        },
        "scheduler_job_enabled": {
          "const": false
        },
        "scheduler_dispatch_performed": {
          "const": false
        },
        "task_created_by_scheduler": {
          "const": false
        },
        "monitoring_policy_activated": {
          "const": false
        },
        "alert_delivery_performed": {
          "const": false
        },
        "automatic_remediation_performed": {
          "const": false
        },
        "kill_switch_triggered": {
          "const": false
        },
        "sandbox_created": {
          "const": false
        },
        "sandbox_test_executed": {
          "const": false
        },
        "filesystem_write_performed": {
          "const": false
        },
        "network_call_performed": {
          "const": false
        },
        "subprocess_performed": {
          "const": false
        },
        "secret_access_performed": {
          "const": false
        },
        "executor_candidate_registered": {
          "const": false
        },
        "executor_registry_mutation_allowed": {
          "const": false
        },
        "executor_activation_allowed": {
          "const": false
        },
        "executor_handoff_allowed": {
          "const": false
        },
        "runtime_mutation_allowed": {
          "const": false
        },
        "external_execution_allowed": {
          "const": false
        },
        "financial_execution_allowed": {
          "const": false
        },
        "side_effects_allowed": {
          "const": false
        },
        "permission_expansion_allowed": {
          "const": false
        },
        "authority_expansion_allowed": {
          "const": false
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "audit_refs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
