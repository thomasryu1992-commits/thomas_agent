{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "permission_decision.v0.4.schema.json",
  "title": "Thomas Permission Decision v0.3 Review-Only Foundation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "permission_decision_id",
    "trace_id",
    "task_id",
    "task_revision",
    "core_context_binding_id",
    "operating_policy",
    "requested_by",
    "fingerprint_payload",
    "action_fingerprint",
    "authority",
    "risk",
    "decision",
    "approval",
    "runtime_effect",
    "lifecycle",
    "audit_refs"
  ],
  "properties": {
    "schema_version": {
      "const": "permission_decision.v0.4"
    },
    "permission_decision_id": {
      "type": "string",
      "pattern": "^permdec_[A-Za-z0-9._:-]+$"
    },
    "trace_id": {
      "type": "string",
      "pattern": "^trace_[A-Za-z0-9._-]+$"
    },
    "task_id": {
      "type": "string",
      "pattern": "^task_[A-Za-z0-9._-]+$"
    },
    "task_revision": {
      "type": "integer",
      "minimum": 1
    },
    "core_context_binding_id": {
      "type": "string",
      "pattern": "^ccb-[A-Za-z0-9._:-]+$"
    },
    "operating_policy": {
      "description": "Current records bind the canonical Governance Policy. The legacy binding is accepted only to preserve historical record compatibility.",
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "policy_id",
            "policy_version",
            "policy_ref"
          ],
          "properties": {
            "policy_id": {
              "const": "thomas.governance.policy"
            },
            "policy_version": {
              "const": "1.1.0"
            },
            "policy_ref": {
              "const": "governance/GOVERNANCE_POLICY.yaml"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "policy_id",
            "policy_version",
            "policy_ref"
          ],
          "properties": {
            "policy_id": {
              "const": "thomas.permission_approval.operating_policy"
            },
            "policy_version": {
              "const": "0.1.0"
            },
            "policy_ref": {
              "const": "docs/runtime-contracts/THOMAS_PERMISSION_APPROVAL_OPERATING_POLICY_V0.1.yaml"
            }
          }
        }
      ]
    },
    "requested_by": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "actor_type",
        "actor_id",
        "role_id",
        "role_version",
        "assignment_id"
      ],
      "properties": {
        "actor_type": {
          "enum": [
            "real_thomas",
            "thomas_prime",
            "role",
            "program",
            "tool",
            "system"
          ]
        },
        "actor_id": {
          "type": "string",
          "minLength": 1
        },
        "role_id": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "role_version": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "assignment_id": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      }
    },
    "fingerprint_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "task_id",
        "task_revision",
        "core_context_binding_id",
        "requester_ref",
        "permission_scope",
        "action_type",
        "target_ref",
        "tool_id",
        "program_id",
        "data_scope",
        "content_sha256",
        "amount_decimal",
        "currency",
        "normalized_parameters",
        "expires_at"
      ],
      "properties": {
        "schema_version": {
          "const": "action_fingerprint_payload.v0.1"
        },
        "task_id": {
          "type": "string",
          "pattern": "^task_[A-Za-z0-9._-]+$"
        },
        "task_revision": {
          "type": "integer",
          "minimum": 1
        },
        "core_context_binding_id": {
          "type": "string",
          "pattern": "^ccb-[A-Za-z0-9._:-]+$"
        },
        "requester_ref": {
          "type": "string",
          "minLength": 1
        },
        "permission_scope": {
          "enum": [
            "INTERNAL_READ",
            "INTERNAL_ANALYSIS",
            "DRAFT_CREATION",
            "SIMULATION_VALIDATION",
            "REVIEW_PACKET_CREATION",
            "CANDIDATE_CREATION",
            "CONTROL_CHANNEL_RESPONSE",
            "WORKSPACE_REVERSIBLE_WRITE",
            "GIT_AGENT_BRANCH_CHANGE",
            "LOCAL_BUILD_TEST",
            "LOW_RISK_OPERATIONAL_KNOWLEDGE",
            "FINANCIAL_APPROVED_BUDGET_USE",
            "FINANCIAL_APPROVED_TRADING_USE",
            "EXTERNAL_COMMUNICATION",
            "PUBLICATION",
            "PROTECTED_BRANCH_CHANGE",
            "RELEASE_DEPLOYMENT",
            "FINANCIAL_NEW_COMMITMENT",
            "RUNTIME_GOVERNANCE",
            "DESTRUCTIVE_CHANGE",
            "ROLE_GOVERNANCE",
            "TOOL_PROGRAM_GOVERNANCE",
            "CANDIDATE_ROLE_TRIAL",
            "SENSITIVE_MEMORY_GOVERNANCE",
            "SECURITY_SENSITIVE_CHANGE",
            "AUTHORITY_ESCALATION",
            "SELF_APPROVAL",
            "APPROVAL_REUSE",
            "SECRET_EXFILTRATION",
            "AUDIT_TAMPERING",
            "KILL_SWITCH_BYPASS",
            "UNREGISTERED_RESOURCE_EXECUTION",
            "DISABLED_RESOURCE_EXECUTION",
            "PROTECTED_BRANCH_FORCE_PUSH",
            "UNAPPROVED_HISTORY_REWRITE"
          ]
        },
        "action_type": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.:-]*$"
        },
        "target_ref": {
          "type": "string",
          "minLength": 1
        },
        "tool_id": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "program_id": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "data_scope": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "content_sha256": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "amount_decimal": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^(0|[1-9][0-9]*)(\\.[0-9]+)?$"
        },
        "currency": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[A-Z]{3,12}$"
        },
        "normalized_parameters": {
          "type": "object"
        },
        "expires_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "action_fingerprint": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_permission_level",
        "role_permission_ceiling",
        "assignment_granted_permission_level",
        "effective_permission_level",
        "authority_sufficient",
        "authority_reasons"
      ],
      "properties": {
        "required_permission_level": {
          "enum": [
            "P0",
            "P1",
            "P2",
            "P3",
            "P4",
            "P5",
            "P6"
          ]
        },
        "role_permission_ceiling": {
          "enum": [
            "P0",
            "P1",
            "P2",
            "P3",
            "P4",
            "P5",
            "P6"
          ]
        },
        "assignment_granted_permission_level": {
          "enum": [
            "P0",
            "P1",
            "P2",
            "P3",
            "P4",
            "P5",
            "P6"
          ]
        },
        "effective_permission_level": {
          "enum": [
            "P0",
            "P1",
            "P2",
            "P3",
            "P4",
            "P5",
            "P6"
          ]
        },
        "authority_sufficient": {
          "type": "boolean"
        },
        "authority_reasons": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        }
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "risk_level",
        "risk_reasons",
        "policy_disposition"
      ],
      "properties": {
        "risk_level": {
          "enum": [
            "GREEN",
            "YELLOW",
            "ORANGE",
            "RED"
          ]
        },
        "risk_reasons": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "policy_disposition": {
          "enum": [
            "ALLOW",
            "EXECUTE_AND_REPORT",
            "APPROVAL_REQUIRED",
            "BLOCK"
          ]
        }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "permission_decision",
        "decision_reasons",
        "constraints"
      ],
      "properties": {
        "permission_decision": {
          "enum": [
            "ALLOW",
            "EXECUTE_AND_REPORT",
            "APPROVAL_REQUIRED",
            "BLOCK"
          ]
        },
        "decision_reasons": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "constraints": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "approval_required",
        "approval_id",
        "approval_status"
      ],
      "properties": {
        "approval_required": {
          "type": "boolean"
        },
        "approval_id": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^approval_[A-Za-z0-9._:-]+$"
        },
        "approval_status": {
          "enum": [
            "NOT_REQUIRED",
            "PENDING"
          ]
        }
      }
    },
    "runtime_effect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "executor_handoff_allowed",
        "external_execution_allowed",
        "financial_execution_allowed",
        "runtime_mutation_allowed",
        "tool_enablement_allowed",
        "program_enablement_allowed",
        "permission_expansion_allowed"
      ],
      "properties": {
        "mode": {
          "const": "REVIEW_ONLY"
        },
        "executor_handoff_allowed": {
          "const": false
        },
        "external_execution_allowed": {
          "const": false
        },
        "financial_execution_allowed": {
          "const": false
        },
        "runtime_mutation_allowed": {
          "const": false
        },
        "tool_enablement_allowed": {
          "const": false
        },
        "program_enablement_allowed": {
          "const": false
        },
        "permission_expansion_allowed": {
          "const": false
        }
      }
    },
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision_status",
        "created_at",
        "expires_at",
        "supersedes"
      ],
      "properties": {
        "decision_status": {
          "enum": [
            "ACTIVE",
            "SUPERSEDED",
            "EXPIRED"
          ]
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "expires_at": {
          "type": "string",
          "format": "date-time"
        },
        "supersedes": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^permdec_[A-Za-z0-9._:-]+$"
          },
          "uniqueItems": true
        }
      }
    },
    "audit_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "authority": {
            "properties": {
              "authority_sufficient": {
                "const": false
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "decision": {
            "properties": {
              "permission_decision": {
                "const": "BLOCK"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "decision": {
            "properties": {
              "permission_decision": {
                "const": "APPROVAL_REQUIRED"
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "approval": {
            "properties": {
              "approval_required": {
                "const": true
              },
              "approval_id": {
                "type": "string",
                "pattern": "^approval_[A-Za-z0-9._:-]+$"
              },
              "approval_status": {
                "const": "PENDING"
              }
            }
          }
        }
      },
      "else": {
        "properties": {
          "approval": {
            "properties": {
              "approval_required": {
                "const": false
              },
              "approval_id": {
                "type": "null"
              },
              "approval_status": {
                "const": "NOT_REQUIRED"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "fingerprint_payload": {
            "properties": {
              "amount_decimal": {
                "type": "string"
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "fingerprint_payload": {
            "properties": {
              "currency": {
                "type": "string"
              }
            }
          }
        }
      },
      "else": {
        "properties": {
          "fingerprint_payload": {
            "properties": {
              "currency": {
                "type": "null"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "fingerprint_payload": {
            "properties": {
              "currency": {
                "type": "string"
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "fingerprint_payload": {
            "properties": {
              "amount_decimal": {
                "type": "string"
              }
            }
          }
        }
      },
      "else": {
        "properties": {
          "fingerprint_payload": {
            "properties": {
              "amount_decimal": {
                "type": "null"
              }
            }
          }
        }
      }
    }
  ]
}
