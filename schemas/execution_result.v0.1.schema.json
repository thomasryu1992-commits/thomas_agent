{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "execution_result.v0.1.schema.json",
  "title": "Thomas Execution Result v0.1 Review-Only",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "execution_result_id",
    "execution_request_id",
    "execution_request_ref",
    "execution_request_fingerprint",
    "trace_id",
    "task_id",
    "task_revision",
    "core_context_binding_id",
    "result_status",
    "execution_evidence",
    "output",
    "metrics",
    "error",
    "runtime_effect",
    "lifecycle",
    "audit_refs"
  ],
  "properties": {
    "schema_version": {
      "const": "execution_result.v0.1"
    },
    "execution_result_id": {
      "type": "string",
      "pattern": "^execres_[A-Za-z0-9._:-]+$"
    },
    "execution_request_id": {
      "type": "string",
      "pattern": "^execreq_[A-Za-z0-9._:-]+$"
    },
    "execution_request_ref": {
      "type": "string",
      "minLength": 1
    },
    "execution_request_fingerprint": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "task_revision": {
      "type": "integer",
      "minimum": 1
    },
    "core_context_binding_id": {
      "type": "string",
      "minLength": 1
    },
    "result_status": {
      "enum": [
        "NOT_EXECUTED",
        "BLOCKED",
        "PREVIEWED",
        "EXPIRED",
        "SUPERSEDED"
      ]
    },
    "execution_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "execution_performed",
        "executor_called",
        "execution_attempt_id",
        "started_at",
        "finished_at",
        "tool_execution_performed",
        "program_execution_performed",
        "external_side_effect_performed",
        "financial_side_effect_performed",
        "runtime_mutation_performed",
        "side_effect_summary"
      ],
      "properties": {
        "execution_performed": {
          "const": false
        },
        "executor_called": {
          "const": false
        },
        "execution_attempt_id": {
          "type": "null"
        },
        "started_at": {
          "type": "null"
        },
        "finished_at": {
          "type": "null"
        },
        "tool_execution_performed": {
          "const": false
        },
        "program_execution_performed": {
          "const": false
        },
        "external_side_effect_performed": {
          "const": false
        },
        "financial_side_effect_performed": {
          "const": false
        },
        "runtime_mutation_performed": {
          "const": false
        },
        "side_effect_summary": {
          "type": "array",
          "maxItems": 0
        }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "output_refs",
        "output_sha256",
        "preview_summary",
        "block_reasons"
      ],
      "properties": {
        "output_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "output_sha256": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^sha256:[0-9a-f]{64}$"
          },
          "uniqueItems": true
        },
        "preview_summary": {
          "type": "string"
        },
        "block_reasons": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime_seconds",
        "tool_calls",
        "program_calls",
        "external_calls",
        "cost_decimal",
        "cost_currency"
      ],
      "properties": {
        "runtime_seconds": {
          "const": 0
        },
        "tool_calls": {
          "const": 0
        },
        "program_calls": {
          "const": 0
        },
        "external_calls": {
          "const": 0
        },
        "cost_decimal": {
          "const": "0"
        },
        "cost_currency": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[A-Z]{3}$"
        }
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "error_code",
        "error_message"
      ],
      "properties": {
        "error_code": {
          "type": [
            "string",
            "null"
          ]
        },
        "error_message": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "runtime_effect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "grants_permission",
        "grants_approval",
        "grants_authority",
        "grants_execution",
        "grants_activation",
        "executor_handoff_allowed",
        "side_effects_allowed",
        "runtime_mutation_allowed"
      ],
      "properties": {
        "mode": {
          "const": "REVIEW_ONLY"
        },
        "grants_permission": {
          "const": false
        },
        "grants_approval": {
          "const": false
        },
        "grants_authority": {
          "const": false
        },
        "grants_execution": {
          "const": false
        },
        "grants_activation": {
          "const": false
        },
        "executor_handoff_allowed": {
          "const": false
        },
        "side_effects_allowed": {
          "const": false
        },
        "runtime_mutation_allowed": {
          "const": false
        }
      }
    },
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "created_at",
        "supersedes"
      ],
      "properties": {
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "supersedes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "audit_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  }
}
